  <metadata>
    <name>Stelvio Pass (Passo dello Stelvio)</name>
    <desc>Classic ascent from Prato allo Stelvio to the summit of Stelvio Pass (2757m), the highest paved mountain pass in the Eastern Alps. Famous for its 48 numbered hairpin turns on the north side. 24.3 km, ~1800m elevation gain.</desc>
    <author><name>RallyTrax Synthetic Test Data</name></author>
    <time>2026-03-20T08:00:00Z</time>
    <bounds minlat="46.5290" minlon="10.4530" maxlat="46.6290" maxlon="10.5340"/>
  </metadata>
