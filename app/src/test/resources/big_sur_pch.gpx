  <metadata>
    <name>Pacific Coast Highway - Big Sur</name>
    <desc>California Highway 1 through Big Sur, from Carmel Highlands to Ragged Point. One of the world's most scenic coastal drives, featuring dramatic cliffs, winding turns above the Pacific Ocean, and elevation changes from sea level to 1000+ feet. Approximately 75 miles of winding coastal road.</desc>
    <author><name>RallyTrax Synthetic Test Data</name></author>
    <time>2026-03-20T09:00:00Z</time>
    <bounds minlat="35.7720" minlon="-121.5100" maxlat="36.4320" maxlon="-121.8960"/>
  </metadata>
