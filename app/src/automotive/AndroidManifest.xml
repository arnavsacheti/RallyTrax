<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Android Automotive OS declares the hardware feature. Required so the
         car launcher surfaces the app on AAOS devices. -->
    <uses-feature
        android:name="android.hardware.type.automotive"
        android:required="true" />

    <application>
        <!-- AAOS launcher entry — the Car App Library activity (provided by
             androidx.car.app:app-automotive) binds RallyTraxCarAppService and
             renders the Car App screens natively. -->
        <activity
            android:name="androidx.car.app.activity.CarAppActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:icon="@mipmap/ic_launcher"
            android:theme="@android:style/Theme.DeviceDefault.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data
                android:name="distractionOptimized"
                android:value="true" />
        </activity>
    </application>
</manifest>
